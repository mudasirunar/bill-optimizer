<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_dark">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- HEADER CRUMB -->
        <LinearLayout
            android:id="@+id/breadcrumb_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textColor="@color/emerald_light"
                android:textSize="10sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginHorizontal="6dp"
                android:src="@android:drawable/ic_media_play"
                android:tint="@color/text_dim"
                tools:ignore="UseAppTint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appliance Simulator"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-black"
            android:text="The Neural Sandbox"
            android:textColor="@color/text_white"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/breadcrumb_layout" />

        <TextView
            android:id="@+id/tv_sub"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Test billing scenarios and simulate appliance additions before they impact your real bill."
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <TextView
            android:id="@+id/model_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/badge_status_live"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="⚙ NEPRA 2026 PRO-RATA ENGINE"
            android:textColor="@color/emerald_light"
            android:textSize="9sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_sub" />

        <!-- ==============================================
             SECTION 1: QUICK BILL CALCULATOR CARD
             ============================================== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/calc_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_emerald_border"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/model_badge">

            <!-- Section Title -->
            <LinearLayout
                android:id="@+id/calc_title_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_today"
                    android:tint="@color/emerald_light"
                    tools:ignore="UseAppTint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-black"
                    android:text="Quick Bill Calculator"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/calc_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Enter data to see the exact NEPRA 2026 PKR breakdown instantly."
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/calc_title_layout" />

            <!-- Row 1 Inputs -->
            <LinearLayout
                android:id="@+id/calc_row1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/calc_subtitle">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Units (kWh)"
                        android:textColor="@color/text_dim"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_calc_units"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/input_field_bg"
                        android:hint="e.g. 250"
                        android:inputType="number"
                        android:paddingHorizontal="12dp"
                        android:textColor="@color/text_white"
                        android:textColorHint="@color/text_dim"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Billing Days"
                        android:textColor="@color/text_dim"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_calc_days"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/input_field_bg"
                        android:inputType="number"
                        android:paddingHorizontal="12dp"
                        android:text="30"
                        android:textColor="@color/text_white"
                        android:textColorHint="@color/text_dim"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 Inputs -->
            <LinearLayout
                android:id="@+id/calc_row2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/calc_row1">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Load (Sanctioned)"
                        android:textColor="@color/text_dim"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <!-- Spinner for load -->
                    <Spinner
                        android:id="@+id/sp_calc_load"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/input_field_bg"
                        android:dropDownWidth="match_parent" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tariff Slabs"
                        android:textColor="@color/text_dim"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <!-- Spinner for category -->
                    <Spinner
                        android:id="@+id/sp_calc_cat"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/input_field_bg"
                        android:dropDownWidth="match_parent" />
                </LinearLayout>
            </LinearLayout>

            <!-- Result panel container -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/calc_result_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/card_emerald_border"
                android:padding="12dp"
                app:layout_constraintTop_toBottomOf="@id/calc_row2">

                <!-- Idle state view -->
                <LinearLayout
                    android:id="@+id/layout_calc_idle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fill in all fields above to instantly calculate bill."
                        android:textColor="@color/text_dim"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Active state dynamic result -->
                <LinearLayout
                    android:id="@+id/layout_calc_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ESTIMATED TOTAL BILL"
                            android:textColor="@color/text_dim"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_calc_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-black"
                            android:text="Rs. 12,300"
                            android:textColor="@color/emerald_light"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ENERGY CHARGES"
                                android:textColor="@color/text_dim"
                                android:textSize="8sp" />

                            <TextView
                                android:id="@+id/tv_calc_energy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Rs. 8,400"
                                android:textColor="@color/text_white"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FIXED &amp; TAXES"
                                android:textColor="@color/text_dim"
                                android:textSize="8sp" />

                            <TextView
                                android:id="@+id/tv_calc_taxes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Rs. 3,900"
                                android:textColor="@color/text_white"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ==============================================
             SECTION 2: APPLIANCE LOAD BUILDER
             ============================================== -->
        <TextView
            android:id="@+id/tv_builder_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif-black"
            android:text="Appliance Load Builder"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/calc_section" />

        <TextView
            android:id="@+id/tv_builder_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Pick appliances, set usage hours, and simulate the PKR cost impact on your bill."
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_builder_title" />

        <!-- Tabs categories switcher (Horizontal list) -->
        <HorizontalScrollView
            android:id="@+id/cats_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/tv_builder_sub">

            <LinearLayout
                android:id="@+id/layout_cat_tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <!-- Dynamic Tab items will be added in Kotlin or stubbed here -->
                <TextView
                    android:id="@+id/tab_cooling"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_status_live"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="❄ Cooling"
                    android:textColor="@color/emerald_light"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_kitchen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/card_emerald_border"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="🍽 Kitchen"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_utilities"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/card_emerald_border"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="🔌 Utilities"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_entertainment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/card_emerald_border"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="📺 Entertainment"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Dynamic Appliance Catalog Grid Layout (Vertical Stack for list items in mobile) -->
        <LinearLayout
            android:id="@+id/appliance_catalog_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/cats_scroll">

            <!-- Catalog Items dynamically loaded via Adapter inside active ListView/RecyclerView.
                 For premium XML structure, we outline a standard container layout. -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:padding="20dp"
                android:text="Loading Sandbox Catalog..."
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- SIMULATION BASKET CARD -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/basket_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/card_emerald_border"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/appliance_catalog_container">

            <TextView
                android:id="@+id/tv_basket_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Simulation Basket"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_basket_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0 appliances added"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_basket_title" />

            <TextView
                android:id="@+id/btn_clear_basket"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="🗑 Clear"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Empty basket placeholder view -->
            <LinearLayout
                android:id="@+id/layout_basket_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                app:layout_constraintTop_toBottomOf="@id/tv_basket_count">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Tap any appliance tile above to add it to your active simulation."
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Active Selected Items List Container -->
            <LinearLayout
                android:id="@+id/basket_items_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tv_basket_count">

                <!-- Dynamic Item rows added inside code. We will implement beautiful row XML files for these items. -->

            </LinearLayout>

            <!-- Basket calculations footer -->
            <LinearLayout
                android:id="@+id/basket_footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/basket_items_container">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_color" />

                <!-- Baseline units option -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Your Monthly Baseline Units (kWh)"
                    android:textColor="@color/text_dim"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_baseline"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/input_field_bg"
                    android:hint="e.g. 200"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_dim"
                    android:textSize="13sp" />

                <!-- Action Sim button -->
                <Button
                    android:id="@+id/btn_run_sim"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/button_gradient"
                    app:backgroundTint="@null"
                    android:text="⚡ Calculate PKR Impact"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <!-- Compare result strip container -->
                <LinearLayout
                    android:id="@+id/compare_strip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/badge_status_live"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_sim_result_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/emerald_light"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="Simulated Load adds +140 units. Bill increases from Rs. 4,500 to Rs. 8,900 (+Rs. 4,400)." />
                </LinearLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
