# ──────────────────────────────────────────────────────────
# 1. PYTHON & SYSTEM FILTERS
# ──────────────────────────────────────────────────────────
backend/venv/
**/__pycache__/
**/*.pyc
.DS_Store
.vscode/

# ──────────────────────────────────────────────────────────
# 2. DATA FOLDER LOGIC (backend/data)
# ──────────────────────────────────────────────────────────

# Ignore all raw source data
backend/data/raw/

# Ignore everything in processed (per-house folders, temporary CSVs)
backend/data/processed/*

# ── EXCEPTION RULES (White-listing the Essentials) ──

# KEEP the models folder (Required for RF, LSTM, and KNN inference)
!backend/data/processed/models/

# ──────────────────────────────────────────────────────────
# 3. SECURITY SENSITIVE FILES
# ──────────────────────────────────────────────────────────

# Environmental secrets
.env
backend/.env

# WARNING: If you are using a PRIVATE GitHub repo, you can 
# comment out the line below to push the key to Render. 
# If your repo is PUBLIC, keep it ignored and use Render 'Secret Files'.
backend/serviceAccountKey.json

# ──────────────────────────────────────────────────────────
# 4. ANDROID SYSTEM & BUILD FILTERS
# ──────────────────────────────────────────────────────────
# Local Android SDK configuration
android_app/local.properties
android_app/*/local.properties

# Gradle caches, logs and temporary files
android_app/.gradle/
android_app/build/
android_app/*/build/
android_app/.kotlin/

# Android Studio / IntelliJ IDE configurations
android_app/*.iml
android_app/.idea/
android_app/out/

# Keystores, signing certificates and credentials
android_app/*.jks
android_app/*.keystore
android_app/signing/

# Native builds & profiles
android_app/.cxx/
android_app/.externalNativeBuild/
android_app/captures/

# Compiled Application Packages (APKs, App Bundles, Profiles)
android_app/**/*.apk
android_app/**/*.ap_
android_app/**/*.aab
android_app/app/release/

# Project Documentation Folder (FYP)
fyp-docs/
